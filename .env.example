# =============================================================================
#  .env.example — Variáveis de ambiente para o docker-compose
#
#  Uso:
#      cp .env.example .env
#      nano .env           # preencher os valores reais
#
#  ATENÇÃO: O ficheiro .env NUNCA deve ser versionado (está no .gitignore)
#
#  Nota: todas as credenciais (IMAP e TG100) estão no config.ini
#        Este ficheiro serve apenas para variáveis de build/runtime do Docker
# =============================================================================

# Fuso horário do container (para que os logs mostrem a hora correta)
TZ=Europe/Lisbon

# UID/GID do utilizador do host — preenchido automaticamente pelo setup.sh
# Garante que os ficheiros nos volumes (logs, models) têm as permissões correctas
APPUSER_UID=1001
APPUSER_GID=1001

# =============================================================================
#  Servidor de email interno (opcional — profile "mailserver")
#
#  Deixar MAIL_ACCOUNT e MAIL_PASSWORD em branco para usar servidor externo.
#  Se preenchidos, o setup.sh cria a conta e o docker-compose sobe o mailserver.
#
#  Após activar, aponta config.ini [imap] para:
#      server   = 127.0.0.1
#      port     = 143
#      use_ssl  = false
#      user     = <MAIL_ACCOUNT>
#      password = <MAIL_PASSWORD>
#
#  Os sistemas externos enviam alertas via SMTP para a porta 25 deste servidor.
# =============================================================================
MAIL_DOMAIN=alertas.local
MAIL_ACCOUNT=alertas@alertas.local
MAIL_PASSWORD=
